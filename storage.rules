rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ─── User avatars ────────────────────────────────────────────────────────
    // Each user uploads their own avatar; all authenticated users can read.
    // SVG excluded — it can contain embedded scripts.

    match /avatars/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(jpeg|png|gif|webp)');
    }

    // ─── Assignment attachments ───────────────────────────────────────────────
    // Only teachers/admins may upload; authenticated users may read.
    // Restricted to common document and image types; max 10 MB.

    match /assignments/{assignmentId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType.matches(
             'image/(jpeg|png|gif|webp)|application/pdf|text/plain'
           );
    }

    // ─── Deny everything else ────────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
